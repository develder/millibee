# ─────────────────────────────────────────────
# MilliBee Docker Configuration
# Copy to .env (same directory) and customize
# ─────────────────────────────────────────────

# Path to workspace on the host (bind mount)
# Contains memory vault, skills, projects — all accessible on the host
WORKSPACE_PATH=../data/workspace

# ─────────────────────────────────────────────
# SSH TUI Channel
# ─────────────────────────────────────────────

# Host port for SSH TUI access
SSH_HOST_PORT=2222

# ─────────────────────────────────────────────
# Crawl4AI (Deep Scraper)
# ─────────────────────────────────────────────

# Host port for debugging / playground (0 = don't expose)
CRAWL4AI_HOST_PORT=11235

# Max concurrent crawl tasks
CRAWL4AI_MAX_CONCURRENT=5

# Optional: API token for authentication (empty = no auth)
CRAWL4AI_API_TOKEN=

# ─────────────────────────────────────────────
# YouTube Transcript API
# ─────────────────────────────────────────────

# Host port for debugging
YT_TRANSCRIPT_HOST_PORT=8200

# ─────────────────────────────────────────────
# Whisper ASR (Speech-to-Text)
# ─────────────────────────────────────────────

# Host port for debugging / Swagger docs
WHISPER_HOST_PORT=9000

# Whisper model: tiny, base, small, medium, large-v3
# Larger = better quality but slower and more memory
WHISPER_MODEL=base
