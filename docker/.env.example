# ─────────────────────────────────────────────
# PicoClaw Docker Configuration
# Kopieer naar ../.env (project root) en pas aan
# ─────────────────────────────────────────────

# Pad naar memory vault op de host (bind mount)
# Dit maakt het vault beschikbaar buiten de container
MEMORY_VAULT_PATH=./data/memory

# ─────────────────────────────────────────────
# Crawl4AI (Deep Scraper)
# ─────────────────────────────────────────────

# Host port voor debugging / playground (0 = niet exposen)
CRAWL4AI_HOST_PORT=11235

# Max gelijktijdige crawl taken
CRAWL4AI_MAX_CONCURRENT=5

# Optioneel: API token voor authenticatie (leeg = geen auth)
CRAWL4AI_API_TOKEN=
