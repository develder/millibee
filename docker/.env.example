# ─────────────────────────────────────────────
# MilliBee Docker Configuration
# Copy to .env (same directory) and customize
# ─────────────────────────────────────────────

# Pad naar memory vault op de host (bind mount)
# Dit maakt het vault beschikbaar buiten de container
MEMORY_VAULT_PATH=../data/memory

# ─────────────────────────────────────────────
# SSH TUI Channel
# ─────────────────────────────────────────────

# Host port for SSH TUI access
SSH_HOST_PORT=2222

# ─────────────────────────────────────────────
# Crawl4AI (Deep Scraper)
# ─────────────────────────────────────────────

# Host port voor debugging / playground (0 = niet exposen)
CRAWL4AI_HOST_PORT=11235

# Max gelijktijdige crawl taken
CRAWL4AI_MAX_CONCURRENT=5

# Optioneel: API token voor authenticatie (leeg = geen auth)
CRAWL4AI_API_TOKEN=

# ─────────────────────────────────────────────
# YouTube Transcript API
# ─────────────────────────────────────────────

# Host port voor debugging
YT_TRANSCRIPT_HOST_PORT=8200

# ─────────────────────────────────────────────
# Whisper ASR (Speech-to-Text)
# ─────────────────────────────────────────────

# Host port voor debugging / Swagger docs
WHISPER_HOST_PORT=9000

# Whisper model: tiny, base, small, medium, large-v3
# Groter = betere kwaliteit maar trager en meer geheugen
WHISPER_MODEL=base
